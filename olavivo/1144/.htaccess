# ============================================================
# /olavivo/1144/ — folder-level override to allow all crawlers
# ============================================================

<RequireAll>
    Require all granted
</RequireAll>

Options -Indexes

# Hostinger ModSecurity v1 (legacy) — per official Hostinger KB
SecFilterEngine Off
SecFilterScanPOST Off

# ModSecurity v2/v3
<IfModule mod_security.c>
    SecRuleEngine Off
</IfModule>
<IfModule mod_security2.c>
    SecRuleEngine Off
</IfModule>

<IfModule mod_headers.c>
    Header set X-Robots-Tag "all"
</IfModule>
