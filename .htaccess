# ============================================================
# moneywise2026.com — root .htaccess
# Allow all bots and crawlers; override Hostinger ModSecurity.
# ============================================================

# Apache 2.4: grant access to everyone
<RequireAll>
    Require all granted
</RequireAll>

# Disable directory listing (security) but allow file access
Options -Indexes +FollowSymLinks

# --- Disable ModSecurity (Hostinger official syntax) ---
# Hostinger documents these legacy directives in their KB:
#   https://www.hostinger.com/support/1583370
SecFilterEngine Off
SecFilterScanPOST Off

# --- Disable ModSecurity v2/v3 (newer servers) ---
<IfModule mod_security.c>
    SecRuleEngine Off
    SecRequestBodyAccess Off
</IfModule>
<IfModule mod_security2.c>
    SecRuleEngine Off
</IfModule>

# Make sure mod_rewrite is on (some Hostinger boxes need this)
<IfModule mod_rewrite.c>
    RewriteEngine On
</IfModule>

# Crawler-friendly headers
<IfModule mod_headers.c>
    Header set X-Robots-Tag "all"
    Header unset X-Frame-Options
</IfModule>

# Friendly MIME types
AddType text/html .html
AddDefaultCharset UTF-8

# Custom error page
ErrorDocument 404 /404.html
